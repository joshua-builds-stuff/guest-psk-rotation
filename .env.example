# Juniper Mist API Configuration
# ------------------------------------------------------------------
# This is an EXAMPLE. Do not edit this file by hand for real use --
# run  python setup_guest_wlan.py  which creates/populates .env
# for you (and validates the credentials against Mist first).
#
# .env holds a live API token: keep it private, never commit it.
# ------------------------------------------------------------------

# Cloud instance the org lives in (bare host, no /api/v1). Set by setup.
MIST_API_URL=https://api.mist.com

# End-user API token (secret).
MIST_API_TOKEN=your-mist-api-token-here

# Organization ID.
MIST_ORG_ID=00000000-0000-0000-0000-000000000000

# --- Filled in by setup_guest_wlan.py after you pick the guest SSID ---

# The Wireless LAN Template the guest SSID belongs to.
MIST_WLAN_TEMPLATE_ID=

# The WLAN ID whose guest portal password gets rotated.
MIST_WLAN_ID=

# The SSID name (for display / logging only).
MIST_WLAN_SSID=Guest-WiFi

# Save a JSON backup of the WLAN before each change? true/false (default false).
# Set during setup; can be overridden per-run with --backup / --no-backup.
MIST_BACKUP_JSON=false
